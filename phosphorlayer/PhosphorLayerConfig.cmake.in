@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Keep the minimum Qt in sync with the top-level project — consumers
# running older Qt would otherwise fail later inside this library's
# headers with a confusing template / missing-symbol error rather than
# a clean find_package rejection at configure time.
find_dependency(Qt6 6.6 COMPONENTS Core Gui Qml Quick)
find_dependency(PhosphorShell)

include("${CMAKE_CURRENT_LIST_DIR}/PhosphorLayerTargets.cmake")

check_required_components(PhosphorLayer)
