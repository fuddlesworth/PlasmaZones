@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Mirror the PUBLIC link set in CMakeLists.txt. (PhosphorDBus /
# PhosphorServiceIconTheme are PRIVATE links added in milestone 3, so they are
# intentionally absent here.)
find_dependency(Qt6 6.6 COMPONENTS Core Qml DBus)

include("${CMAKE_CURRENT_LIST_DIR}/PhosphorServiceNotificationsTargets.cmake")

check_required_components(PhosphorServiceNotifications)
