@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Mirror the PUBLIC link set in CMakeLists.txt. (PhosphorServiceIconTheme is a
# PRIVATE link, used only in the .cpp, so it is intentionally absent here.)
find_dependency(Qt6 6.6 COMPONENTS Core Qml DBus Gui)

include("${CMAKE_CURRENT_LIST_DIR}/PhosphorServiceNotificationsTargets.cmake")

check_required_components(PhosphorServiceNotifications)
