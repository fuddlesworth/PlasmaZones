@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Mirror the PUBLIC link set in CMakeLists.txt. Every entry here needs
# to be resolvable by find_package consumers so the exported targets
# file can wire transitively.
find_dependency(Qt6 6.6 COMPONENTS Core Qml DBus)

include("${CMAKE_CURRENT_LIST_DIR}/PhosphorServiceUPowerTargets.cmake")

check_required_components(PhosphorServiceUPower)
