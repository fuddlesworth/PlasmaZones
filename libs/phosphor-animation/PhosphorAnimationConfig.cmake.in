@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Core library — always needed. Pin Qt to match the library's build
# minimum; without the version guard a consumer on Qt 6.5 resolves
# find_package(PhosphorAnimation) cleanly and then fails later with a
# cryptic missing-symbol at link time.
find_dependency(Qt6 6.6 COMPONENTS Core Gui)

include("${CMAKE_CURRENT_LIST_DIR}/PhosphorAnimationTargets.cmake")

# QML component — opt-in via `find_package(PhosphorAnimation COMPONENTS QML)`.
# The QML targets are installed separately (only when PHOSPHOR_ANIMATION_QML_INSTALL
# was ON at build time); the exported CMake file is optional so core-only
# consumers don't require Qt Quick / Qml to find_package successfully.
if("QML" IN_LIST PhosphorAnimation_FIND_COMPONENTS)
    find_dependency(Qt6 6.6 COMPONENTS Quick Qml)
    if(EXISTS "${CMAKE_CURRENT_LIST_DIR}/PhosphorAnimationQmlTargets.cmake")
        include("${CMAKE_CURRENT_LIST_DIR}/PhosphorAnimationQmlTargets.cmake")
        set(PhosphorAnimation_QML_FOUND TRUE)
    else()
        set(PhosphorAnimation_QML_FOUND FALSE)
    endif()
endif()

check_required_components(PhosphorAnimation)
