@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(Qt6 6.6 COMPONENTS Core Gui Quick Qml)
# No version pin on the Phosphor* siblings: they version independently
# and substituting PHOSPHORSHELL_VERSION here would reject any sibling
# released at a different version even though the ABIs are compatible.
# Each lib publishes its own SameMajorVersion ConfigVersion file —
# downstreams that want strict pinning add explicit `find_package`
# calls before find_package(PhosphorShell).
find_dependency(PhosphorLayer CONFIG)
find_dependency(PhosphorRendering CONFIG)
find_dependency(PhosphorShaders CONFIG)
find_dependency(PhosphorWayland CONFIG)

include("${CMAKE_CURRENT_LIST_DIR}/PhosphorShellTargets.cmake")

check_required_components(PhosphorShell)
