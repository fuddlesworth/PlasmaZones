@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Mirror the PUBLIC link set in CMakeLists.txt — every entry here needs
# to be resolvable by find_package consumers so the exported targets
# file can wire transitively.
find_dependency(Qt6 6.10 COMPONENTS Core Gui)
find_dependency(PhosphorGeometry)
find_dependency(PhosphorProtocol)

include("${CMAKE_CURRENT_LIST_DIR}/PhosphorEngineTargets.cmake")

check_required_components(PhosphorEngine)
