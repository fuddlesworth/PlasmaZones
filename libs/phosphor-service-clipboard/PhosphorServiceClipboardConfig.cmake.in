@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Mirror the PUBLIC link set in CMakeLists.txt. (PhosphorWayland is a PRIVATE
# link: the data-control client is used inside the .cpp and never appears in the
# public headers, so consumers neither include nor link it.)
find_dependency(Qt6 6.6 COMPONENTS Core Qml)

include("${CMAKE_CURRENT_LIST_DIR}/PhosphorServiceClipboardTargets.cmake")

check_required_components(PhosphorServiceClipboard)
