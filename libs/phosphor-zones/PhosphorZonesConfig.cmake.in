@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Mirror the PUBLIC link set in CMakeLists.txt — every entry here is
# resolvable by find_package consumers so the exported targets file can
# wire transitively. PhosphorIdentity / PhosphorScreens are PRIVATE, so
# they ride in the exported targets as `$<LINK_ONLY:...>` and don't need
# their own find_dependency.
find_dependency(Qt6 6.6 COMPONENTS Core Gui)
find_dependency(PhosphorLayoutApi)
find_dependency(PhosphorGeometry)
find_dependency(PhosphorWindowRules)

include("${CMAKE_CURRENT_LIST_DIR}/PhosphorZonesTargets.cmake")

check_required_components(PhosphorZones)
