@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Core library — always needed. Pin Qt to match the library's build
# minimum; without the version guard a consumer on Qt 6.5 resolves
# find_package(PhosphorSurface) cleanly and then fails later with a
# cryptic missing-symbol at link time.
find_dependency(Qt6 6.6 COMPONENTS Core Gui)

# PhosphorRegistry is a PUBLIC link dependency — SurfaceShaderRegistry's public
# header exposes Registry<SurfacePack> + MetadataPackLoader<SurfacePack> — so the
# exported target references PhosphorRegistry::PhosphorRegistry and a standalone
# find_package consumer must resolve it.
find_dependency(PhosphorRegistry 0.1.0)

# PhosphorFsLoader is a PUBLIC link dependency in its own right — the public
# SurfaceShaderRegistry header consumes PhosphorFsLoader::LiveReload and
# PhosphorFsLoader::RegistrationOrder directly in addSearchPath/addSearchPaths
# signatures, and the exported target links PhosphorFsLoader::PhosphorFsLoader
# PUBLIC. Declare it explicitly rather than relying on PhosphorRegistry's Config
# re-exporting it transitively, matching the sibling PhosphorShaders/PhosphorTiles
# Configs and the directness of this library's header coupling.
find_dependency(PhosphorFsLoader 0.1.0)

# PhosphorShaders is a PUBLIC link dependency — SurfaceShaderContract.h
# includes <PhosphorShaders/CustomParamsKey.h> and the registry uses the
# slot-assignment / preamble helpers, so a standalone consumer must resolve it.
find_dependency(PhosphorShaders)

include("${CMAKE_CURRENT_LIST_DIR}/PhosphorSurfaceTargets.cmake")

check_required_components(PhosphorSurface)
