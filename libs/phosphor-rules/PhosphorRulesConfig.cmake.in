@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Mirror the PUBLIC link set in CMakeLists.txt — every entry here is
# resolvable by find_package consumers so the exported targets file can wire
# transitively. PhosphorIdentity is PRIVATE, so it rides in the exported
# targets as `$<LINK_ONLY:...>` and needs no find_dependency.
find_dependency(Qt6 6.6 COMPONENTS Core)
find_dependency(PhosphorProtocol)

include("${CMAKE_CURRENT_LIST_DIR}/PhosphorRulesTargets.cmake")

check_required_components(PhosphorRules)
