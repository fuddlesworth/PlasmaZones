@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Mirror the PUBLIC link set in CMakeLists.txt — PhosphorGeometry /
# PhosphorLayoutApi are NOT PUBLIC here; they arrive transitively via
# PhosphorEngine / PhosphorZones and don't need their own find_dependency.
find_dependency(Qt6 6.10 COMPONENTS Core Gui)
find_dependency(PhosphorEngine)
find_dependency(PhosphorZones)
find_dependency(PhosphorProtocol)

include("${CMAKE_CURRENT_LIST_DIR}/PhosphorSnapEngineTargets.cmake")

check_required_components(PhosphorSnapEngine)
