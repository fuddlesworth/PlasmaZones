@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# The public header <PhosphorRendering/ShaderNodeRhi.h> includes <rhi/qrhi.h>,
# which lives in Qt6::GuiPrivate. Downstream consumers must therefore have the
# private Gui module available; declaring it on the same find_dependency call
# as Core/Gui/Quick keeps the 6.6 version pin in one place and fails fast if
# the dev package isn't installed (instead of failing on the first #include).
find_dependency(Qt6 6.6 COMPONENTS Core Gui GuiPrivate Quick)
find_dependency(PhosphorShaders)

include("${CMAKE_CURRENT_LIST_DIR}/PhosphorRenderingTargets.cmake")

check_required_components(PhosphorRendering)
