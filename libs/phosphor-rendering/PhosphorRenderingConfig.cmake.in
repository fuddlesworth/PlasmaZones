@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(Qt6 COMPONENTS Core Gui Quick)
# The public header <PhosphorRendering/ShaderNodeRhi.h> includes <rhi/qrhi.h>,
# which lives in Qt6::GuiPrivate. Downstream consumers must therefore have the
# private Gui module available; declare it here so find_package(PhosphorRendering)
# fails fast if the dev package isn't installed (instead of failing on the first
# #include).
find_dependency(Qt6GuiPrivate)
find_dependency(PhosphorShell)

include("${CMAKE_CURRENT_LIST_DIR}/PhosphorRenderingTargets.cmake")

check_required_components(PhosphorRendering)
