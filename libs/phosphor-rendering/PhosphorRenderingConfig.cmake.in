@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# The public header <PhosphorRendering/ShaderNodeRhi.h> includes <rhi/qrhi.h>,
# which lives in Qt6::GuiPrivate. Distros split how that target is provided:
# Arch / openSUSE ship a standalone Qt6GuiPrivateConfig.cmake, while Fedora
# defines the Qt6::GuiPrivate target inside Qt6GuiConfig.cmake — see the
# matching guarded pattern in the project's top-level CMakeLists.txt.
# Mirror it here so find_package(PhosphorRendering) is portable across both.
find_dependency(Qt6 6.10 COMPONENTS Core Gui Quick)
if(NOT TARGET Qt6::GuiPrivate)
    find_dependency(Qt6GuiPrivate 6.6)
endif()
find_dependency(PhosphorShaders)

include("${CMAKE_CURRENT_LIST_DIR}/PhosphorRenderingTargets.cmake")

check_required_components(PhosphorRendering)
