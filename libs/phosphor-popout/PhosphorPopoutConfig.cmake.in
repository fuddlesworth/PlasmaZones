@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# The installed package exposes only the C++ core
# (PhosphorPopout::PhosphorPopout), which links Core/Gui/Qml. The
# PhosphorPopoutQml static-QML module is in-tree-only today (see the
# README's Dependencies section); when its installed deployment lands
# alongside the layer-shell transport, the find_dependency line below
# will gain Quick.
find_dependency(Qt6 6.6 COMPONENTS Core Gui Qml)

include("${CMAKE_CURRENT_LIST_DIR}/PhosphorPopoutTargets.cmake")

check_required_components(PhosphorPopout)
