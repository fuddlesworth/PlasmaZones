[Desktop Entry]
Type=Application
Name=PlasmaZones Daemon
Comment=Window tiling zone management daemon
Exec=@KDE_INSTALL_FULL_BINDIR@/plasmazonesd
Icon=plasmazones
NoDisplay=true
X-KDE-StartupNotify=false
X-DBUS-ServiceName=org.plasmazones
# Categories aren't user-visible (NoDisplay=true) but KWin's
# fetchRestrictedDBusInterfacesFromPid + the portal layer both inspect
# them, so keep at least one Qt/KDE marker present.
Categories=Qt;KDE;Utility;
Keywords=window;tiling;zones;daemon;
