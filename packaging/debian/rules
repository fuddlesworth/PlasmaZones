#!/usr/bin/make -f
# PlasmaZones Debian build rules
# SPDX-License-Identifier: GPL-3.0-or-later

export DEB_BUILD_MAINT_OPTIONS = hardening=+all

# Exact KWin version pin. The kwin-effect plugin's IID embeds KWin's upstream
# version string; KWin refuses to load effects whose IID doesn't match its own
# version, including across patch bumps (e.g. 6.7.0 -> 6.7.1). We capture the
# build-time kwin-dev version (kwin-dev is an explicit Build-Depend and shares
# its source-package version with kwin-common) and substitute it into
# debian/control as ${kwin:Version} so the package refuses to install on a
# mismatched KWin instead of installing silently broken.
KWIN_VERSION := $(shell dpkg-query -W -f='$${Version}' kwin-dev 2>/dev/null)

%:
	dh $@ --buildsystem=cmake+ninja

override_dh_auto_configure:
	dh_auto_configure -- \
		-DCMAKE_BUILD_TYPE=RelWithDebInfo \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DCMAKE_INSTALL_LIBDIR=lib/$(DEB_HOST_MULTIARCH) \
		-DBUILD_TESTING=OFF

override_dh_auto_test:
	# Skip tests during package build

override_dh_gencontrol:
	dh_gencontrol -- -Vkwin:Version="$(KWIN_VERSION)"
