{
    "id": "phosphor-stream",
    "name": "Phosphor Stream",
    "description": "The window pours into its zone as separated luminous streams. Each stream runs on its own slightly offset clock and bows apart mid flight, carrying a different stop of the brand gradient, with ember sparks shed in the wake. The streams reunite exactly at the destination, so the settled window carries no residue.",
    "author": "PlasmaZones",
    "version": "1.0",
    "category": "Geometry",
    "appliesTo": ["geometry"],
    "fboExtent": "surface",
    "geometryGrid": 40,
    "fragmentShader": "effect.frag",
    "vertexShader": "effect.vert",
