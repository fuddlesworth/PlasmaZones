{
    "id": "phosphor-peek",
    "name": "Phosphor Peek",
    "description": "Reveals the desktop in the official Phosphor style. The windows de-energize like a circuit shutting down, a front sweeps across along glowing traces, and the pixels drain along them into the brand gradient as the desktop is left behind.",
    "author": "PlasmaZones",
    "version": "1.0",
    "category": "Reveal",
    "appliesTo": ["desktop"],
    "fragmentShader": "effect.frag",
    "parameters": [
        {
            "id": "dirX",
            "name": "Drain Direction X",
            "type": "float",
            "default": 1.0,
            "min": -1.0,
            "max": 1.0
        },
        {
            "id": "dirY",
            "name": "Drain Direction Y",
            "type": "float",
            "default": 1.0,
            "min": -1.0,
            "max": 1.0
        },
        {
            "id": "scale",
            "name": "Trace Density",
            "type": "float",
            "default": 6.0,
            "min": 2.0,
            "max": 16.0
        },
        {
            "id": "softness",
            "name": "Front Softness",
            "type": "float",
            "default": 0.35,
            "min": 0.05,
            "max": 1.0
        },
        {
            "id": "glow",
            "name": "Front Glow",
            "type": "float",
            "default": 1.0,
            "min": 0.0,
            "max": 2.0
        },
        {
            "id": "dim",
            "name": "De-energize Dim",
            "type": "float",
            "default": 0.4,
            "min": 0.0,
            "max": 1.0
        },
        {
            "id": "colorCyan",
            "name": "Gradient Cyan",
            "type": "color",
            "default": "#22D3EE"
        },
        {
            "id": "colorBlue",
            "name": "Gradient Blue",
            "type": "color",
            "default": "#3B82F6"
        },
        {
            "id": "colorPurple",
            "name": "Gradient Purple",
            "type": "color",
            "default": "#A855F7"
        },
        {
            "id": "colorRose",
            "name": "Gradient Rose",
            "type": "color",
            "default": "#F43F5E"
        }
    ]
}
