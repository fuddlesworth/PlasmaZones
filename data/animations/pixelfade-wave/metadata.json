            "type": "float",
            "default": 800.0,
            "min": 100.0,
            "max": 1600.0
        },
        {
            "id": "waveSlope",
            "name": "Wave Slope",
            "type": "float",
            "default": 0.6,
            "min": 0.0,
            "max": 2.0
        }
    ]
