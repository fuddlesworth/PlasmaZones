{
    "id": "desktop-aretha",
    "name": "Desktop Aretha",
    "description": "Switches desktops hexagon by hexagon along a diagonal data sweep, with a glowing cyan leading edge and pink glitch flashes in the Aretha style.",
    "author": "PlasmaZones",
    "version": "1.0",
    "category": "Glitch",
    "appliesTo": ["desktop"],
    "fragmentShader": "effect.frag",
    "parameters": [
        {
            "id": "hexSize",
            "name": "Hex Size",
            "type": "float",
            "default": 44.0,
            "min": 12.0,
            "max": 120.0
        },
        {
            "id": "scatter",
            "name": "Scatter",
            "type": "float",
            "default": 0.5,
            "min": 0.0,
            "max": 1.0
        },
        {
            "id": "glitch",
            "name": "Glitch",
            "type": "float",
            "default": 0.55,
            "min": 0.0,
            "max": 1.0
        },
        {
            "id": "edgeGlow",
            "name": "Edge Glow",
            "type": "float",
            "default": 1.0,
            "min": 0.0,
            "max": 2.0
        },
        {
            "id": "colorEdge",
            "name": "Edge Color",
            "type": "color",
            "default": "#55AAFF"
        },
        {
            "id": "colorGlitch",
            "name": "Glitch Color",
            "type": "color",
            "default": "#FF557F"
        }
    ]
}
