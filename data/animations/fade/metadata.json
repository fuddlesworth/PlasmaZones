{
    "id": "fade",
    "name": "Fade",
    "description": "Gentle scale-and-fade transition. Opening eases scale from 0.95 to 1.0 while the window fades in. Closing eases scale from 1.0 to 0.95 while it fades out.",
    "author": "PlasmaZones (ported from liixini/shaders, https://github.com/liixini/shaders)",
    "version": "1.0",
    "category": "Fade",
    "fragmentShader": "effect.frag",
    "parameters": [
        {
            "id": "scaleAmount",
            "name": "Zoom Amount",
            "type": "float",
            "default": 0.05,
            "min": 0.0,
            "max": 0.3
        },
        {
            "id": "revealStart",
            "name": "Reveal Start",
            "type": "float",
            "default": 0.0,
            "min": 0.0,
            "max": 0.49
        },
        {
            "id": "revealEnd",
            "name": "Reveal End",
            "type": "float",
            "default": 1.0,
            "min": 0.51,
            "max": 1.0
        }
    ]
}
