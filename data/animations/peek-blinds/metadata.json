{
    "id": "peek-blinds",
    "name": "Peek Blinds",
    "description": "Splits the screen into venetian slats that tilt open one after another, so the windows collapse to thin bands and the desktop shows through as the reveal sweeps across.",
    "author": "PlasmaZones",
    "version": "1.0",
    "category": "Reveal",
    "appliesTo": ["desktop"],
    "fragmentShader": "effect.frag",
    "parameters": [
        {
            "id": "slatCount",
            "name": "Slat Count",
            "type": "float",
            "default": 12.0,
            "min": 2.0,
            "max": 40.0
        },
        {
            "id": "vertical",
            "name": "Vertical Slats",
            "type": "bool",
            "default": false
        },
        {
            "id": "softness",
            "name": "Edge Softness",
            "type": "float",
            "default": 0.3,
            "min": 0.0,
            "max": 1.0
        }
    ]
}
