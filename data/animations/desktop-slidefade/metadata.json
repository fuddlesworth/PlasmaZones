{
    "id": "desktop-slidefade",
    "name": "Desktop Slide & Fade",
    "description": "Slides the desktops a short way while cross-fading between them, the way Hyprland's slidefade switches workspaces.",
    "author": "PlasmaZones",
    "version": "1.0",
    "category": "Slide",
    "appliesTo": ["desktop"],
    "fragmentShader": "effect.frag",
    "parameters": [
        {
            "id": "dirX",
            "name": "Direction X",
            "type": "float",
            "default": 1.0,
            "min": -1.0,
            "max": 1.0
        },
        {
            "id": "dirY",
            "name": "Direction Y",
            "type": "float",
            "default": 0.0,
            "min": -1.0,
            "max": 1.0
        },
        {
            "id": "travel",
            "name": "Slide Distance",
            "type": "float",
            "default": 0.25,
            "min": 0.0,
            "max": 1.0
        }
    ]
}
