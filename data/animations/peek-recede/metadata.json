            "min": 0.0,
            "max": 1.0
        },
        {
            "id": "centerY",
            "name": "Center Y",
            "type": "float",
            "default": 0.5,
            "min": 0.0,
            "max": 1.0
        },
        {
            "id": "dim",
            "name": "Dim Strength",
            "type": "float",
