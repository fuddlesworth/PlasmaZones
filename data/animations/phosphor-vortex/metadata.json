{
    "id": "phosphor-vortex",
    "name": "Phosphor Vortex",
    "description": "Grab a window and a plasma vortex around the cursor inhales it, pulling the surface into glowing streamlines that erode as they feed in. The plasma keeps orbiting for as long as the drag is held, stretches into a comet along the path while you move, and releases the window back when you let go.",
    "author": "PlasmaZones",
    "version": "1.0",
