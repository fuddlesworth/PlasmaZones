{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://plasmazones.kde.org/schemas/animation-metadata.schema.json",
    "title": "PlasmaZones Animation Shader Metadata",
    "description": "metadata.json for a bundled or user animation-shader pack. Core identity and the parameter contract are enforced; optional rendering keys (vertexShader, fboExtent, textures, appliesTo, geometryGrid) are allowed through.",
    "type": "object",
    "required": ["id", "name", "description", "author", "version", "category", "fragmentShader", "parameters"],
    "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "author": { "type": "string" },
        "version": { "type": "string" },
        "category": { "type": "string" },
        "fragmentShader": { "type": "string", "minLength": 1 },
        "vertexShader": { "type": "string" },
        "parameters": {
            "type": "array",
            "items": { "$ref": "#/definitions/parameter" }
        }
    },
    "definitions": {
        "parameter": {
            "type": "object",
            "required": ["id", "name", "type", "default"],
            "properties": {
                "id": { "type": "string", "minLength": 1 },
                "name": { "type": "string" },
                "description": { "type": "string" },
                "type": {
                    "type": "string",
                    "enum": ["float", "int", "bool", "color"],
                    "description": "Marshalling type of the uniform; an unknown type cannot be bound, so it is rejected."
                },
                "default": {
                    "type": ["number", "string", "boolean"],
                    "description": "Default value; a string for color (#rrggbb), number for float/int, boolean for bool."
                },
                "min": { "type": "number" },
                "max": { "type": "number" }
            }
        }
    }
}
