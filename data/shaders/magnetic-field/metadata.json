{
    "id": "magnetic-field",
    "name": "Magnetic Field",
    "category": "Energy",
    "description": "Mouse-reactive magnetic field effect with orbiting particles and energy waves",
    "author": "PlasmaZones",
    "version": "1.0",
    "fragmentShader": "effect.frag",
    "vertexShader": "zone.vert",
    "parameters": [
        {"id": "fieldStrength", "name": "Field Strength", "group": "Field", "type": "float", "default": 1.0, "min": 0.2, "max": 2.0},
        {"id": "waveSpeed", "name": "Wave Speed", "group": "Animation", "type": "float", "default": 1.5, "min": 0.5, "max": 3.0},
        {"id": "rippleSize", "name": "Ripple Size", "group": "Field", "type": "float", "default": 0.5, "min": 0.1, "max": 1.0},
        {"id": "glowIntensity", "name": "Glow Intensity", "group": "Appearance", "type": "float", "default": 0.6, "min": 0.1, "max": 1.0},
        {"id": "particleCount", "name": "Particle Count", "group": "Particles", "type": "int", "default": 30, "min": 10, "max": 50},
        {"id": "particleSize", "name": "Particle Size", "group": "Particles", "type": "float", "default": 1.5, "min": 0.5, "max": 3.0},
        {"id": "distortionAmount", "name": "Distortion", "group": "Field", "type": "float", "default": 0.4, "min": 0.0, "max": 1.0},
        {"id": "audioReactivity", "name": "Audio Reactivity", "group": "Audio", "type": "float", "default": 1.0, "min": 0.0, "max": 2.0},
        {"id": "nebulaIntensity", "name": "Nebula Intensity", "group": "Background", "type": "float", "default": 0.15, "min": 0.0, "max": 0.4},
        {"id": "shockwaveStrength", "name": "Shockwave Strength", "group": "Audio", "type": "float", "default": 1.0, "min": 0.0, "max": 3.0},
        {"id": "fillOpacity", "name": "Fill Opacity", "group": "Appearance", "type": "float", "default": 0.85, "min": 0.4, "max": 1.0},
        {"id": "fieldColor", "name": "Field Color", "group": "Colors", "type": "color", "default": "#8b5cf6"},
        {"id": "highlightColor", "name": "Highlight Color", "group": "Colors", "type": "color", "default": "#facc15"},
        {"id": "coronaSpread", "name": "Corona Arc Spread", "group": "Labels", "type": "float", "default": 3.5, "min": 1.0, "max": 6.0},
        {"id": "fieldBright", "name": "Field Core Brightness", "group": "Labels", "type": "float", "default": 2.2, "min": 1.0, "max": 4.0},
        {"id": "arcReact", "name": "Arc Reactivity", "group": "Labels", "type": "float", "default": 1.0, "min": 0.0, "max": 2.0},
        {"id": "arcThickness", "name": "Field Line Thickness", "group": "Field", "type": "float", "default": 0.006, "min": 0.002, "max": 0.015},
        {"id": "gridFrequency", "name": "Grid Frequency", "group": "Field", "type": "int", "default": 20, "min": 8, "max": 40},
        {"id": "showLabels", "name": "Show Labels", "group": "Labels", "type": "bool", "default": true}
    ]
}
