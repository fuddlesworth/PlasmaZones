{
    "id": "particle-aurora",
    "name": "Particle Aurora",
    "category": "Audio Visualizer",
    "description": "Flowing particle aurora driven by compute shaders. Thousands of particles rise and drift, colored by zone palette and pulsing with audio. Enable CAVA audio visualization in settings for full effect.",
    "author": "PlasmaZones",
    "version": "1.0",
    "fragmentShader": "effect.frag",
    "vertexShader": "zone.vert",
    "computeShader": "particles.comp",
    "particleCount": 8192,
    "parameters": [
        {"id": "spawnRate", "name": "Spawn Rate", "group": "Particles", "type": "float", "slot": 0, "default": 0.8, "min": 0.1, "max": 1.0},
        {"id": "lifetime", "name": "Lifetime", "group": "Particles", "type": "float", "slot": 1, "default": 4.0, "min": 1.0, "max": 10.0},
        {"id": "gravity", "name": "Gravity", "group": "Physics", "type": "float", "slot": 2, "default": -0.02, "min": -0.1, "max": 0.1},
        {"id": "turbulence", "name": "Turbulence", "group": "Physics", "type": "float", "slot": 3, "default": 0.3, "min": 0.0, "max": 1.0},
        {"id": "particleSize", "name": "Particle Size", "group": "Particles", "type": "float", "slot": 4, "default": 3.0, "min": 1.0, "max": 8.0},
        {"id": "glowIntensity", "name": "Glow Intensity", "group": "Appearance", "type": "float", "slot": 5, "default": 1.5, "min": 0.5, "max": 4.0},
        {"id": "audioReactivity", "name": "Audio Reactivity", "group": "Audio", "type": "float", "slot": 6, "default": 1.5, "min": 0.0, "max": 3.0},
        {"id": "driftSpeed", "name": "Drift Speed", "group": "Physics", "type": "float", "slot": 7, "default": 0.5, "min": 0.0, "max": 2.0},
        {"id": "primaryColor", "name": "Primary Color", "group": "Colors", "type": "color", "slot": 0, "default": "#0a0020"},
        {"id": "auroraColor1", "name": "Aurora Color 1", "group": "Colors", "type": "color", "slot": 1, "default": "#00ff88"},
        {"id": "auroraColor2", "name": "Aurora Color 2", "group": "Colors", "type": "color", "slot": 2, "default": "#0088ff"},
        {"id": "auroraColor3", "name": "Aurora Color 3", "group": "Colors", "type": "color", "slot": 3, "default": "#ff00aa"},
        {"id": "particleCount", "name": "Particle Count", "group": "Particles", "type": "int", "slot": -1, "default": 8192, "min": 512, "max": 16384},
        {"id": "showLabels", "name": "Show Labels", "group": "Labels", "type": "bool", "slot": 8, "default": true}
    ]
}
