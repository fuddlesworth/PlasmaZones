{
    "id": "neon-city",
    "name": "Neon City",
    "category": "3D",
    "description": "Fly past an infinite grid of pixel buildings lit by cascading neon signs and drifting street lights. Bass lifts the fog and pumps the street lights, treble flickers the signs, mids cycle the window palette — camera stays stable. Adapted from 'Neon City' by nikitamashchenko (Shadertoy). Enable CAVA audio visualization in settings.",
    "author": "PlasmaZones (adapted from nikitamashchenko, Shadertoy)",
    "version": "1.0",
    "fragmentShader": "effect.frag",
    "vertexShader": "zone.vert",
    "multipass": true,
    "depthBuffer": true,
    "bufferShader": "buffer.frag",
    "parameters": [
        {"id": "reactivity",    "name": "Audio Reactivity",       "group": "Audio",      "type": "float", "slot": 0,  "default": 1.5,  "min": 0.0, "max": 3.0},
        {"id": "speed",         "name": "Flight Speed",           "group": "Camera",     "type": "float", "slot": 1,  "default": 1.0,  "min": 0.25, "max": 2.5},
        {"id": "lightSpeed",    "name": "Light Drift Speed",      "group": "Camera",     "type": "float", "slot": 2,  "default": 1.0,  "min": 0.25, "max": 3.0},
        {"id": "fastMode",      "name": "Fast Descent",           "group": "Camera",     "type": "bool",  "slot": 3,  "default": false},
        {"id": "cameraDist",    "name": "Camera Distance",        "group": "Camera",     "type": "float", "slot": 4,  "default": 11.0, "min": 5.0, "max": 16.0},
        {"id": "zoom",          "name": "Zoom",                   "group": "Camera",     "type": "float", "slot": 5,  "default": 2.5,  "min": 1.8, "max": 5.0},
        {"id": "fogDensity",    "name": "Fog Density",            "group": "Appearance", "type": "float", "slot": 6,  "default": 0.7,  "min": 0.3, "max": 1.1},
        {"id": "fogOffset",     "name": "Fog Start Distance",     "group": "Appearance", "type": "float", "slot": 7,  "default": 7.0,  "min": 3.0, "max": 14.0},
        {"id": "bassImpact",    "name": "Bass Impact",            "group": "Audio",      "type": "float", "slot": 8,  "default": 1.5,  "min": 0.0, "max": 4.0},
        {"id": "trebleImpact",  "name": "Treble Impact",          "group": "Audio",      "type": "float", "slot": 9,  "default": 1.5,  "min": 0.0, "max": 4.0},
        {"id": "midsImpact",    "name": "Mids Impact",            "group": "Audio",      "type": "float", "slot": 10, "default": 1.0,  "min": 0.0, "max": 4.0},
        {"id": "idleSpeed",     "name": "Idle Animation Speed",   "group": "Animation",  "type": "float", "slot": 11, "default": 1.0,  "min": 0.0, "max": 3.0},
        {"id": "fillOpacity",   "name": "Fill Opacity",           "group": "Appearance", "type": "float", "slot": 12, "default": 0.92, "min": 0.75, "max": 1.0},
        {"id": "showLabels",    "name": "Show Labels",            "group": "Labels",     "type": "bool",  "slot": 13, "default": true},
        {"id": "dofStrength",   "name": "Depth of Field",         "group": "Appearance", "type": "float", "slot": 14, "default": 0.35, "min": 0.0,  "max": 1.2},
        {"id": "edgeGlow",      "name": "Edge Glow",              "group": "Appearance", "type": "float", "slot": 15, "default": 1.4,  "min": 0.5,  "max": 3.0},
        {"id": "primaryColor",  "name": "Fog / Primary Color",    "group": "Colors",     "type": "color", "slot": 0,  "default": "#400052"},
        {"id": "accentColor",   "name": "Window Accent / Cyan",   "group": "Colors",     "type": "color", "slot": 1,  "default": "#66ccff"},
        {"id": "bassColor",     "name": "Bass / Deep Window",     "group": "Colors",     "type": "color", "slot": 2,  "default": "#0000cc"},
        {"id": "lightColor",    "name": "Street Light Color",     "group": "Colors",     "type": "color", "slot": 3,  "default": "#cc7326"}
    ]
}
