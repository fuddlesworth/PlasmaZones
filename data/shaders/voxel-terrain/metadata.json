{
    "id": "voxel-terrain",
    "name": "Voxel Terrain",
    "description": "Fly through an infinite 3D voxel world with floating islands and overhangs. Audio drives wireframe glow, face emission, and volumetric haze — geometry stays stable. Dark and moody with bright neon edges that pulse with the beat. Enable CAVA audio visualization in settings.",
    "author": "PlasmaZones",
    "version": "1.0",
    "fragmentShader": "effect.frag",
    "vertexShader": "zone.vert",
    "parameters": [
        {"id": "reactivity", "name": "Audio Reactivity", "group": "Audio", "type": "float", "slot": 0, "default": 1.5, "min": 0.5, "max": 3.0},
        {"id": "terrainScale", "name": "Terrain Scale", "group": "Geometry", "type": "float", "slot": 1, "default": 0.1, "min": 0.04, "max": 0.25},
        {"id": "maxHeight", "name": "Max Height", "group": "Geometry", "type": "float", "slot": 2, "default": 6.0, "min": 2.0, "max": 12.0},
        {"id": "edgeGlow", "name": "Edge Glow", "group": "Appearance", "type": "float", "slot": 3, "default": 1.5, "min": 0.0, "max": 4.0},
        {"id": "cameraHeight", "name": "Camera Height", "group": "Camera", "type": "float", "slot": 4, "default": 8.0, "min": 3.0, "max": 20.0},
        {"id": "scrollSpeed", "name": "Scroll Speed", "group": "Camera", "type": "float", "slot": 5, "default": 2.0, "min": 0.5, "max": 15.0},
        {"id": "cameraTilt", "name": "Camera Tilt", "group": "Camera", "type": "float", "slot": 6, "default": 0.35, "min": 0.0, "max": 1.0},
        {"id": "fillOpacity", "name": "Fill Opacity", "group": "Appearance", "type": "float", "slot": 7, "default": 0.92, "min": 0.5, "max": 1.0},
        {"id": "wireThickness", "name": "Edge Width", "group": "Appearance", "type": "float", "slot": 8, "default": 0.10, "min": 0.02, "max": 0.35},
        {"id": "fogDensity", "name": "Fog Density", "group": "Appearance", "type": "float", "slot": 9, "default": 0.05, "min": 0.01, "max": 0.20},
        {"id": "bassImpact", "name": "Bass Impact", "group": "Audio", "type": "float", "slot": 10, "default": 2.0, "min": 0.5, "max": 4.0},
        {"id": "idleSpeed", "name": "Idle Animation Speed", "group": "Animation", "type": "float", "slot": 11, "default": 1.0, "min": 0.0, "max": 3.0},
        {"id": "primaryColor", "name": "Primary Color", "group": "Colors", "type": "color", "slot": 0, "default": "#0f142e"},
        {"id": "accentColor", "name": "Accent / Glow Color", "group": "Colors", "type": "color", "slot": 1, "default": "#00d4ff"},
        {"id": "bassColor", "name": "Bass Color", "group": "Colors", "type": "color", "slot": 2, "default": "#e600aa"},
        {"id": "gridColor", "name": "Grid/Wire Color", "group": "Colors", "type": "color", "slot": 3, "default": "#99b3e6"},
        {"id": "showLabels", "name": "Show Labels", "group": "Labels", "type": "bool", "slot": 12, "default": true}
    ]
}
